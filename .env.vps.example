# Docker Hub images (repo can be in separate GitHub repositories)
FRONTEND_IMAGE=docker.io/<dockerhub_user>/gasy-frontend:sha-<git_commit>
BACKEND_IMAGE=docker.io/<dockerhub_user>/gasy-backend:sha-<git_commit>

# PostgreSQL
POSTGRES_DB=agriculture
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
